# crablite configuration — copy to `.env`. Everything here is optional; env vars
# override ~/.crablite/config.json.

# Model to use via Codex (default: gpt-5.5)
# CRABLITE_MODEL=gpt-5.5

# The agent's display name / persona handle (also used for group @mention detection)
# CRABLITE_AGENT_NAME=Crab

# REQUIRED to enable the agent. Comma-separated phone numbers or JIDs allowed to
# talk to it. Closed by default (empty ⇒ ignores everyone). "*" = anyone (warned).
# CRABLITE_ALLOW_FROM=34600111222

# Turn nightly self-learning ("dreaming") off with 0
# CRABLITE_DREAMING=1

# Log level: debug | info | warn | error
# CRABLITE_LOG_LEVEL=info

# --- Google (gog) ---------------------------------------------------------
# Default Google account so the agent doesn't need --account each time
# GOG_ACCOUNT=you@gmail.com
# Encrypted keyring so Google tokens survive restarts (Docker):
# GOG_KEYRING_BACKEND=file
# GOG_KEYRING_PASSWORD=change-me

# --- Proactivity ----------------------------------------------------------
# WhatsApp chat id (JID) for a once-daily proactive check-in guided by HEARTBEAT.md.
# Leave unset to disable check-ins (scheduled reminders still work regardless).
# CRABLITE_PRIMARY_CHAT=34600111222@s.whatsapp.net

# Note: voice notes and images are handled with your Codex credential — no extra
# keys or providers. Nothing to configure here.

# --- Docker ---------------------------------------------------------------
# On Apple Silicon / arm64, build gog for the right arch:
# GOG_ASSET=gogcli_linux_arm64.tar.gz
